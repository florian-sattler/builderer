{
  "$defs": {
    "Action": {
      "additionalProperties": false,
      "description": "A generic action with multiple commands.\n\nUse this mechanism if other steps aren't sufficient for your usecase.",
      "properties": {
        "type": {
          "const": "action",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "description": "Name printed before running the action",
          "title": "Name",
          "type": "string"
        },
        "commands": {
          "description": "List of commands. Each command is a list of strings: the executable followed by arguments.",
          "items": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "title": "Commands",
          "type": "array"
        },
        "post": {
          "description": "Whether to add the action to the post queue",
          "title": "Post",
          "type": "boolean"
        }
      },
      "required": [
        "type",
        "name",
        "commands",
        "post"
      ],
      "title": "Action",
      "type": "object"
    },
    "BuildImage": {
      "additionalProperties": false,
      "description": "Build a docker image and push it to the registry.",
      "properties": {
        "type": {
          "const": "build_image",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "directory": {
          "description": "Directory containing the Dockerfile. This is also used as the build context.",
          "title": "Directory",
          "type": "string"
        },
        "dockerfile": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Path to Dockerfile. Name of the resulting image. Defaults to <directory>/Dockerfile.",
          "title": "Dockerfile"
        },
        "name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Name of the resulting image. Defaults to the name of the Dockerfiles parent directory.",
          "title": "Name"
        },
        "push": {
          "default": true,
          "description": "Whether to push the image. Defaults to True.",
          "title": "Push",
          "type": "boolean"
        },
        "qualified": {
          "default": true,
          "description": "Whether to add the registry path and prefix to the image name. Defaults to True.",
          "title": "Qualified",
          "type": "boolean"
        },
        "extra_tags": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Additional tags to use in this step. Defaults to None.",
          "title": "Extra Tags"
        }
      },
      "required": [
        "type",
        "directory"
      ],
      "title": "BuildImage",
      "type": "object"
    },
    "BuildImages": {
      "additionalProperties": false,
      "description": "Build multiple docker images and push them to the registry.",
      "properties": {
        "type": {
          "const": "build_images",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "directories": {
          "description": "Directories containing each containing Dockerfile.",
          "items": {
            "type": "string"
          },
          "title": "Directories",
          "type": "array"
        },
        "push": {
          "default": true,
          "description": "Whether to push the image. Defaults to True.",
          "title": "Push",
          "type": "boolean"
        },
        "qualified": {
          "default": true,
          "description": "Whether to add the registry path and prefix to the image name. Defaults to True.",
          "title": "Qualified",
          "type": "boolean"
        },
        "extra_tags": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Additional tags to use in this step. Defaults to None.",
          "title": "Extra Tags"
        },
        "num_parallel": {
          "default": 1,
          "description": "Number of parallel executions. Defaults to 1",
          "title": "Num Parallel",
          "type": "integer"
        }
      },
      "required": [
        "type",
        "directories"
      ],
      "title": "BuildImages",
      "type": "object"
    },
    "ExtractFromImage": {
      "additionalProperties": false,
      "description": "Copy a file from within a docker image.",
      "properties": {
        "type": {
          "const": "extract_from_image",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "image": {
          "description": "Name of the image to copy from.",
          "title": "Image",
          "type": "string"
        },
        "path": {
          "description": "Source path inside the image.",
          "title": "Path",
          "type": "string"
        },
        "dest": {
          "description": "Destination paths. The file will be copied to all destinations individually.",
          "items": {
            "type": "string"
          },
          "title": "Dest",
          "type": "array"
        }
      },
      "required": [
        "type",
        "image",
        "path",
        "dest"
      ],
      "title": "ExtractFromImage",
      "type": "object"
    },
    "ForwardImage": {
      "additionalProperties": false,
      "description": "Pull an image from a registry, retag it and push it maybe using new names.",
      "properties": {
        "type": {
          "const": "forward_image",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "description": "Image name to forward.",
          "title": "Name",
          "type": "string"
        },
        "new_name": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Set a new name for the image. By default the basename of the pulled image without the tag is used.",
          "title": "New Name"
        },
        "extra_tags": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Additional tags to use in this step. Defaults to None.",
          "title": "Extra Tags"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "title": "ForwardImage",
      "type": "object"
    },
    "ForwardImages": {
      "additionalProperties": false,
      "description": "Pull images, retag and push them.",
      "properties": {
        "type": {
          "const": "forward_images",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "names": {
          "description": "Image names to forward.",
          "items": {
            "type": "string"
          },
          "title": "Names",
          "type": "array"
        },
        "extra_tags": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Additional tags to use in this step. Defaults to None.",
          "title": "Extra Tags"
        },
        "num_parallel": {
          "default": 4,
          "description": "Number of parallel executions. Defaults to 4",
          "title": "Num Parallel",
          "type": "integer"
        }
      },
      "required": [
        "type",
        "names"
      ],
      "title": "ForwardImages",
      "type": "object"
    },
    "Group": {
      "additionalProperties": false,
      "description": "A group of actions which might be run in parallel.",
      "properties": {
        "type": {
          "const": "group",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "num_parallel": {
          "default": 1,
          "description": "Number of parallel executions. Defaults to {}",
          "title": "Num Parallel",
          "type": "integer"
        },
        "steps": {
          "description": "List of steps to execute.",
          "items": {
            "anyOf": [
              {
                "$ref": "#/$defs/Action"
              },
              {
                "$ref": "#/$defs/BuildImage"
              },
              {
                "$ref": "#/$defs/ExtractFromImage"
              },
              {
                "$ref": "#/$defs/ForwardImage"
              },
              {
                "$ref": "#/$defs/PullImage"
              }
            ]
          },
          "title": "Steps",
          "type": "array"
        }
      },
      "required": [
        "type",
        "steps"
      ],
      "title": "Group",
      "type": "object"
    },
    "Parameters": {
      "additionalProperties": false,
      "description": "Overwrite default parameters. Values set here will in turn be overwritten by command line arguments.",
      "properties": {
        "registry": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Set the registry url. You may include a port using the colon notation (example.com:3000/). This is needed when using a non standard port. Unset by default.",
          "title": "Registry URL"
        },
        "prefix": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Set the directory for all images. This is the image component between registry url and image name. For example on docker hub this is used for the username. Unset by default.",
          "title": "Registry directory"
        },
        "push": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether to allow pushing images.",
          "title": "Allow pushing images"
        },
        "cache": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Whether to allow using cached images. This is especially useful for local builds.",
          "title": "Allow caching images"
        },
        "verbose": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Show issued commands and their live output.",
          "title": "Verbose output"
        },
        "tags": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "One or multiple tags to use for each image. Defaults to ['latest']",
          "title": "Tags to use"
        },
        "simulate": {
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Prevent issuing any commands just do the printing.",
          "title": "Simulate execution"
        },
        "backend": {
          "anyOf": [
            {
              "enum": [
                "docker",
                "podman"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Overwrite the backend used to build, tag and pull images. Defaults to 'docker'",
          "title": "Build Backend"
        },
        "max_parallel": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Limit the maximum number of parallel jobs per step. By default the num_parallel argument of each individual step is used.",
          "title": "Maximum number of parallel jobs"
        }
      },
      "title": "Parameters",
      "type": "object"
    },
    "PullImage": {
      "additionalProperties": false,
      "description": "Pull an image from a registry.\n\nThis might be useful to ensure a local image is up to date (e.g. for local builds).",
      "properties": {
        "type": {
          "const": "pull_image",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "name": {
          "description": "Image name to pull.",
          "title": "Name",
          "type": "string"
        }
      },
      "required": [
        "type",
        "name"
      ],
      "title": "PullImage",
      "type": "object"
    },
    "PullImages": {
      "additionalProperties": false,
      "description": "Pull images from a registry.\n\nThis might be useful to ensure local images are up to date (e.g. for local builds).",
      "properties": {
        "type": {
          "const": "pull_images",
          "description": "Type of the step",
          "title": "Type",
          "type": "string"
        },
        "names": {
          "description": "Image names to pull.",
          "items": {
            "type": "string"
          },
          "title": "Names",
          "type": "array"
        },
        "num_parallel": {
          "default": 4,
          "description": "Number of parallel executions. Defaults to 4",
          "title": "Num Parallel",
          "type": "integer"
        }
      },
      "required": [
        "type",
        "names"
      ],
      "title": "PullImages",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "builderer configuration.",
  "properties": {
    "steps": {
      "description": "List of steps to execute.",
      "items": {
        "anyOf": [
          {
            "$ref": "#/$defs/Action"
          },
          {
            "$ref": "#/$defs/BuildImage"
          },
          {
            "$ref": "#/$defs/BuildImages"
          },
          {
            "$ref": "#/$defs/ExtractFromImage"
          },
          {
            "$ref": "#/$defs/ForwardImage"
          },
          {
            "$ref": "#/$defs/ForwardImages"
          },
          {
            "$ref": "#/$defs/Group"
          },
          {
            "$ref": "#/$defs/PullImage"
          },
          {
            "$ref": "#/$defs/PullImages"
          }
        ]
      },
      "title": "Steps",
      "type": "array"
    },
    "parameters": {
      "$ref": "#/$defs/Parameters"
    }
  },
  "required": [
    "steps"
  ],
  "title": "BuildererConfig",
  "type": "object"
}
